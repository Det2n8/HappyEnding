<?xml version="1.0" encoding="UTF-8"?>
<includes>
  <include file="Variables.xml" />
  <include name="FullBackground">
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <texture colordiffuse="bg">white.png</texture>
    </control>
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <texture>$VAR[HappyEndingFanart]</texture>
      <aspectratio>scale</aspectratio>
      <colordiffuse>33222A38</colordiffuse>
    </control>
  </include>
  <include name="TopBar">
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>96</height>
      <texture colordiffuse="blackfade">white.png</texture>
    </control>
    <control type="label">
      <left>54</left><top>20</top><width>900</width><height>56</height>
      <font>font16</font><textcolor>text</textcolor>
      <label>HappyEnding Preview</label>
    </control>
    <control type="label">
      <right>54</right><top>30</top><width>650</width><height>44</height>
      <font>font13</font><textcolor>muted</textcolor><align>right</align>
      <label>$INFO[System.Date]  $INFO[System.Time]</label>
    </control>
  </include>
  <include name="InfoPanel">
    <control type="group">
      <left>920</left><top>718</top><width>910</width><height>300</height>
      <control type="label">
        <left>0</left><top>0</top><width>910</width><height>58</height>
        <font>font16</font><textcolor>text</textcolor><scroll>true</scroll>
        <label>$INFO[ListItem.Label]</label>
      </control>
      <control type="label">
        <left>0</left><top>62</top><width>910</width><height>38</height>
        <font>font13</font><textcolor>accent2</textcolor>
        <label>$VAR[HappyEndingDuration]   $INFO[ListItem.Year]</label>
      </control>
      <control type="textbox">
        <left>0</left><top>112</top><width>910</width><height>150</height>
        <font>font12</font><textcolor>muted</textcolor>
        <label>$INFO[ListItem.Plot]</label>
        <autoscroll delay="7000" time="2500" repeat="9000">true</autoscroll>
      </control>
    </control>
  </include>
</includes>
