<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">9000</defaultcontrol>
  <controls>
    <include>FullBackground</include>
    <include>TopBar</include>
    <control type="group">
      <left>90</left><top>160</top><width>760</width><height>760</height>
      <control type="label">
        <left>0</left><top>0</top><width>760</width><height>84</height>
        <font>font20</font><textcolor>text</textcolor>
        <label>Browse fast.</label>
      </control>
      <control type="label">
        <left>0</left><top>82</top><width>760</width><height>42</height>
        <font>font13</font><textcolor>muted</textcolor>
        <label>Large preview, tiny clutter.</label>
      </control>
      <control type="list" id="9000">
        <left>0</left><top>170</top><width>680</width><height>430</height>
        <onup>9000</onup><ondown>9000</ondown>
        <itemlayout width="680" height="78">
          <control type="label"><left>26</left><top>15</top><width>620</width><height>48</height><font>font14</font><textcolor>muted</textcolor><label>$INFO[ListItem.Label]</label></control>
        </itemlayout>
        <focusedlayout width="680" height="78">
          <control type="image"><left>0</left><top>0</top><width>680</width><height>72</height><texture colordiffuse="panel2">white.png</texture></control>
          <control type="image"><left>0</left><top>0</top><width>8</width><height>72</height><texture colordiffuse="accent">white.png</texture></control>
          <control type="label"><left>26</left><top>15</top><width>620</width><height>48</height><font>font14</font><textcolor>text</textcolor><label>$INFO[ListItem.Label]</label></control>
        </focusedlayout>
        <content>
          <item><label>Video add-ons</label><onclick>ActivateWindow(Videos,addons://sources/video/,return)</onclick></item>
          <item><label>Files</label><onclick>ActivateWindow(Videos,files,return)</onclick></item>
          <item><label>System settings</label><onclick>ActivateWindow(Settings)</onclick></item>
          <item><label>Reload skin</label><onclick>ReloadSkin()</onclick></item>
        </content>
      </control>
    </control>
    <control type="image">
      <left>1030</left><top>180</top><width>720</width><height>520</height>
      <texture>special://skin/icon.png</texture><aspectratio>keep</aspectratio>
    </control>
  </controls>
</window>
