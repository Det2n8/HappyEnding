<?xml version="1.0" encoding="UTF-8"?>
<includes>
  <variable name="HappyEndingArt">
    <value condition="!String.IsEmpty(ListItem.Art(thumb))">$INFO[ListItem.Art(thumb)]</value>
    <value condition="!String.IsEmpty(ListItem.Art(poster))">$INFO[ListItem.Art(poster)]</value>
    <value condition="!String.IsEmpty(ListItem.Art(icon))">$INFO[ListItem.Art(icon)]</value>
    <value condition="!String.IsEmpty(ListItem.Art(fanart))">$INFO[ListItem.Art(fanart)]</value>
    <value>special://skin/icon.png</value>
  </variable>
  <variable name="HappyEndingFanart">
    <value condition="!String.IsEmpty(ListItem.Art(fanart))">$INFO[ListItem.Art(fanart)]</value>
    <value condition="!String.IsEmpty(ListItem.Art(thumb))">$INFO[ListItem.Art(thumb)]</value>
    <value>special://skin/icon.png</value>
  </variable>
  <variable name="HappyEndingDuration">
    <value condition="!String.IsEmpty(ListItem.Duration)">$INFO[ListItem.Duration]</value>
    <value condition="!String.IsEmpty(ListItem.Label2)">$INFO[ListItem.Label2]</value>
    <value>Length unknown</value>
  </variable>
</includes>
