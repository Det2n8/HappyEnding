<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">50</defaultcontrol>
  <views>50,500,501,502</views>
  <controls>
    <include>FullBackground</include>
    <include>TopBar</include>

    <!-- View 50: user-requested layout, list on left, big image on right -->
    <control type="fixedlist" id="50">
      <left>54</left><top>126</top><width>780</width><height>900</height>
      <focusposition>5</focusposition>
      <orientation>vertical</orientation>
      <viewtype label="HappyEnding list">list</viewtype>
      <onright>50</onright><onleft>50</onleft>
      <pagecontrol>60</pagecontrol>
      <itemlayout width="780" height="78">
        <control type="image"><left>0</left><top>0</top><width>760</width><height>72</height><texture colordiffuse="panel">white.png</texture></control>
        <control type="image"><left>12</left><top>8</top><width>92</width><height>56</height><texture>$VAR[HappyEndingArt]</texture><aspectratio>scale</aspectratio></control>
        <control type="label"><left>122</left><top>12</top><width>610</width><height>30</height><font>font13</font><textcolor>muted</textcolor><label>$INFO[ListItem.Label]</label></control>
        <control type="label"><left>122</left><top>45</top><width>610</width><height>24</height><font>font12</font><textcolor>dim</textcolor><label>$VAR[HappyEndingDuration]</label></control>
      </itemlayout>
      <focusedlayout width="780" height="92">
        <control type="image"><left>0</left><top>0</top><width>780</width><height>88</height><texture colordiffuse="panel2">white.png</texture></control>
        <control type="image"><left>0</left><top>0</top><width>8</width><height>88</height><texture colordiffuse="accent">white.png</texture></control>
        <control type="image"><left>16</left><top>9</top><width>120</width><height>70</height><texture>$VAR[HappyEndingArt]</texture><aspectratio>scale</aspectratio></control>
        <control type="label"><left>154</left><top>12</top><width>590</width><height>38</height><font>font14</font><textcolor>text</textcolor><scroll>true</scroll><label>$INFO[ListItem.Label]</label></control>
        <control type="label"><left>154</left><top>54</top><width>590</width><height>26</height><font>font12</font><textcolor>accent2</textcolor><label>$VAR[HappyEndingDuration]</label></control>
      </focusedlayout>
    </control>

    <control type="scrollbar" id="60">
      <left>840</left><top>126</top><width>8</width><height>900</height>
      <orientation>vertical</orientation>
    </control>

    <control type="group">
      <visible>Control.IsVisible(50)</visible>
      <left>920</left><top>126</top><width>910</width><height>560</height>
      <control type="image">
        <left>0</left><top>0</top><width>910</width><height>560</height>
        <texture colordiffuse="panel">white.png</texture>
      </control>
      <control type="image">
        <left>18</left><top>18</top><width>874</width><height>524</height>
        <texture>$VAR[HappyEndingArt]</texture>
        <aspectratio>keep</aspectratio>
      </control>
    </control>
    <include condition="Control.IsVisible(50)">InfoPanel</include>

    <!-- View 500: poster wall -->
    <control type="panel" id="500">
      <visible>Control.IsVisible(500)</visible>
      <left>58</left><top>126</top><width>1804</width><height>900</height>
      <viewtype label="Poster wall">icon</viewtype>
      <orientation>vertical</orientation>
      <itemlayout width="245" height="335">
        <control type="image"><left>10</left><top>0</top><width>225</width><height>270</height><texture>$VAR[HappyEndingArt]</texture><aspectratio>scale</aspectratio></control>
        <control type="label"><left>8</left><top>278</top><width>230</width><height>52</height><font>font12</font><textcolor>muted</textcolor><align>center</align><label>$INFO[ListItem.Label]</label></control>
      </itemlayout>
      <focusedlayout width="245" height="335">
        <control type="image"><left>0</left><top>0</top><width>245</width><height>330</height><texture colordiffuse="accent">white.png</texture></control>
        <control type="image"><left>8</left><top>8</top><width>229</width><height>270</height><texture>$VAR[HappyEndingArt]</texture><aspectratio>scale</aspectratio></control>
        <control type="label"><left>8</left><top>283</top><width>229</width><height>46</height><font>font12</font><textcolor>text</textcolor><align>center</align><label>$INFO[ListItem.Label]</label></control>
      </focusedlayout>
    </control>

    <!-- View 501: landscape wall -->
    <control type="panel" id="501">
      <visible>Control.IsVisible(501)</visible>
      <left>58</left><top>126</top><width>1804</width><height>900</height>
      <viewtype label="Large landscape thumbs">bigicon</viewtype>
      <orientation>vertical</orientation>
      <itemlayout width="430" height="285">
        <control type="image"><left>10</left><top>0</top><width>405</width><height>220</height><texture>$VAR[HappyEndingArt]</texture><aspectratio>scale</aspectratio></control>
        <control type="label"><left>12</left><top>226</top><width>400</width><height>50</height><font>font12</font><textcolor>muted</textcolor><align>center</align><label>$INFO[ListItem.Label]</label></control>
      </itemlayout>
      <focusedlayout width="430" height="285">
        <control type="image"><left>0</left><top>0</top><width>425</width><height>280</height><texture colordiffuse="accent2">white.png</texture></control>
        <control type="image"><left>8</left><top>8</top><width>409</width><height>220</height><texture>$VAR[HappyEndingArt]</texture><aspectratio>scale</aspectratio></control>
        <control type="label"><left>12</left><top>232</top><width>400</width><height>45</height><font>font12</font><textcolor>text</textcolor><align>center</align><label>$INFO[ListItem.Label]</label></control>
      </focusedlayout>
    </control>

    <!-- View 502: compact list -->
    <control type="list" id="502">
      <visible>Control.IsVisible(502)</visible>
      <left>120</left><top>130</top><width>1680</width><height>880</height>
      <viewtype label="Compact list">list</viewtype>
      <itemlayout width="1680" height="52">
        <control type="label"><left>0</left><top>7</top><width>1320</width><height>38</height><font>font13</font><textcolor>muted</textcolor><label>$INFO[ListItem.Label]</label></control>
        <control type="label"><right>0</right><top>7</top><width>280</width><height>38</height><font>font13</font><textcolor>dim</textcolor><align>right</align><label>$VAR[HappyEndingDuration]</label></control>
      </itemlayout>
      <focusedlayout width="1680" height="58">
        <control type="image"><left>0</left><top>0</top><width>1680</width><height>56</height><texture colordiffuse="panel2">white.png</texture></control>
        <control type="label"><left>20</left><top>9</top><width>1320</width><height>40</height><font>font13</font><textcolor>text</textcolor><label>$INFO[ListItem.Label]</label></control>
        <control type="label"><right>20</right><top>9</top><width>280</width><height>40</height><font>font13</font><textcolor>accent2</textcolor><align>right</align><label>$VAR[HappyEndingDuration]</label></control>
      </focusedlayout>
    </control>
  </controls>
</window>
